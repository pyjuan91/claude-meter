{
  "name": "claude-meter",
  "version": "1.4.0",
  "private": true,
  "description": "Browser extension that displays Claude.ai usage limits as a floating widget.",
  "scripts": {
    "test": "vitest run",
    "test:ci": "vitest run --reporter=verbose",
    "test:watch": "vitest",
    "zip": "cd src && zip -r ../claude-meter-v$(node -p \"require('../package.json').version\").zip manifest.json *.js *.css *.html icons/"
  },
  "devDependencies": {
    "vitest": "^3.0.0"
  }
}
